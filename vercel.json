{
  "crons": [
    { "path": "/api/digest", "schedule": "0 11 * * *" }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/civicscope-admin/index.html" },
    { "source": "/pro",   "destination": "/pro/index.html" },
    { "source": "/ryc/dashboard", "destination": "/ryc-dashboard/index.html" },
    { "source": "/fire-station-cost", "destination": "/fire-station-cost/index.html" },
    { "source": "/public-works-garage-cost", "destination": "/public-works-garage-cost/index.html" },
    { "source": "/community-center-cost", "destination": "/community-center-cost/index.html" },
    { "source": "/splash-pad-cost", "destination": "/splash-pad-cost/index.html" },
    { "source": "/salt-shed-cost", "destination": "/salt-shed-cost/index.html" },
    { "source": "/gc/acme-internal", "destination": "/civicscope-gc/estimator/index.html" },
    { "source": "/gc/:slug", "destination": "/civicscope-gc/index.html" }
  ]
}
